@model AdminPagedListViewModel<ContentPost>

<div class="admin-actions">
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Posts" asp-action="Create">Thêm bài viết</a>
</div>

<div class="admin-panel">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Tiêu đề</th>
                    <th>Danh mục</th>
                    <th>Loại</th>
                    <th>Xuất bản</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <strong>@item.Title</strong>
                            <div class="small text-secondary">@item.Summary</div>
                        </td>
                        <td>@item.Category?.Name</td>
                        <td>@item.PostType</td>
                        <td>@item.PublishedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa bài viết này?');">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="pagination-bar" aria-label="Phân trang bài viết">
            @if (Model.CurrentPage > 1)
            {
                <a class="pagination-bar__link" asp-area="Admin" asp-controller="Posts" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)">Trước</a>
            }
            else
            {
                <span class="pagination-bar__link is-disabled">Trước</span>
            }

            <div class="pagination-bar__pages">
                @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                {
                    if (pageNumber == Model.CurrentPage)
                    {
                        <span class="pagination-bar__page is-active">@pageNumber</span>
                    }
                    else
                    {
                        <a class="pagination-bar__page" asp-area="Admin" asp-controller="Posts" asp-action="Index" asp-route-page="@pageNumber">@pageNumber</a>
                    }
                }
            </div>

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a class="pagination-bar__link" asp-area="Admin" asp-controller="Posts" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)">Sau</a>
            }
            else
            {
                <span class="pagination-bar__link is-disabled">Sau</span>
            }
        </nav>
    }
</div>
