@model IEnumerable<PostCategory>

<div class="admin-actions">
    <a class="btn btn-primary" asp-action="Create">Thêm danh mục</a>
</div>

<div class="admin-panel">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Tên</th>
                    <th>Slug</th>
                    <th>Loại</th>
                    <th>Hiển thị</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Slug</td>
                        <td>@item.PostType</td>
                        <td>@(item.IsVisible ? "Có" : "Không")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Xóa danh mục này?');">Xóa</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
