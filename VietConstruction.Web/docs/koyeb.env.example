ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=8080
ConnectionStrings__MySql=Server=your-mysql-host;Port=3306;Database=viet_construction_cms;User Id=vietconstruction_app;Password=replace-me;Character Set=utf8mb4;SslMode=Required;
CmsSeed__Enabled=true
CmsSeed__AdminEmail=admin@example.com
CmsSeed__AdminPassword=replace-with-strong-password
CmsSeed__AdminFullName=Quan tri he thong
CmsSeed__EditorEmail=editor@example.com
CmsSeed__EditorPassword=replace-with-strong-password
CmsSeed__EditorFullName=Bien tap noi dung
DatabaseInitialization__MaxAttempts=20
DatabaseInitialization__DelaySeconds=5
# Optional if you attach a Koyeb volume for ASP.NET Core Data Protection keys
DataProtection__KeysPath=/var/lib/vietconstruction/keys
