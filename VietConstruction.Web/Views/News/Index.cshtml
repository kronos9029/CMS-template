@model NewsListingPageViewModel
@{
    ViewData["Title"] = Model.Title;
    ViewData["MetaDescription"] = Model.MetaDescription;

    var hero = new PageHeroViewModel
    {
        Eyebrow = Model.Eyebrow,
        Title = Model.HeroTitle,
        Summary = Model.HeroSummary,
        Actions = Model.HeroActions
    };

    string GetPageUrl(int pageNumber)
    {
        return Model.CurrentCategory switch
        {
            "featured" => Url.Action("TinNoiBat", "News", new { page = pageNumber }) ?? "/tin-tuc/tin-noi-bat",
            "announcements" => Url.Action("ThongBao", "News", new { page = pageNumber }) ?? "/tin-tuc/thong-bao",
            _ => Url.Action("Index", "News", new { page = pageNumber }) ?? "/tin-tuc"
        };
    }
}

@await Html.PartialAsync("_PageHero", hero)

<section class="page-shell">
    <div class="container">
        <div class="filter-tabs">
            <a class="@(Model.CurrentCategory == "all" ? "is-active" : string.Empty)" href="/tin-tuc">Tất cả</a>
            <a class="@(Model.CurrentCategory == "featured" ? "is-active" : string.Empty)" href="/tin-tuc/tin-noi-bat">Tin nổi bật</a>
            <a class="@(Model.CurrentCategory == "announcements" ? "is-active" : string.Empty)" href="/tin-tuc/thong-bao">Thông báo</a>
            <a href="/tin-tuc/tuyen-dung">Tuyển dụng</a>
        </div>
        <div class="card-grid card-grid--three">
            @foreach (var article in Model.Articles)
            {
                @await Html.PartialAsync("_ArticleCard", article)
            }
        </div>
        @if (Model.TotalPages > 1)
        {
            <nav class="pagination-bar" aria-label="Phân trang tin tức">
                <a class="pagination-bar__link @(Model.CurrentPage == 1 ? "is-disabled" : null)"
                   href="@(Model.CurrentPage == 1 ? "#" : GetPageUrl(Model.CurrentPage - 1))"
                   aria-disabled="@(Model.CurrentPage == 1 ? "true" : "false")">
                    Trước
                </a>
                <div class="pagination-bar__pages">
                    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                    {
                        <a class="pagination-bar__page @(pageNumber == Model.CurrentPage ? "is-active" : null)"
                           href="@GetPageUrl(pageNumber)">
                            @pageNumber
                        </a>
                    }
                </div>
                <a class="pagination-bar__link @(Model.CurrentPage == Model.TotalPages ? "is-disabled" : null)"
                   href="@(Model.CurrentPage == Model.TotalPages ? "#" : GetPageUrl(Model.CurrentPage + 1))"
                   aria-disabled="@(Model.CurrentPage == Model.TotalPages ? "true" : "false")">
                    Sau
                </a>
            </nav>
        }
    </div>
</section>
