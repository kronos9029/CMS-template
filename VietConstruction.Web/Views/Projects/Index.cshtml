@model ProjectListingPageViewModel
@{
    ViewData["Title"] = Model.Title;
    ViewData["MetaDescription"] = Model.MetaDescription;

    var hero = new PageHeroViewModel
    {
        Eyebrow = Model.Eyebrow,
        Title = Model.HeroTitle,
        Summary = Model.HeroSummary,
        Metrics = Model.HeroMetrics,
        Actions = Model.HeroActions
    };

    string GetPageUrl(int pageNumber)
    {
        return Model.CurrentFilter switch
        {
            "in-progress" => Url.Action("DangThucHien", "Projects", new { page = pageNumber }) ?? "/du-an/dang-thuc-hien",
            "completed" => Url.Action("DaHoanThanh", "Projects", new { page = pageNumber }) ?? "/du-an/da-hoan-thanh",
            _ => Url.Action("Index", "Projects", new { page = pageNumber }) ?? "/du-an"
        };
    }
}

@await Html.PartialAsync("_PageHero", hero)

<section class="page-shell">
    <div class="container">
        <div class="filter-tabs">
            <a class="@(Model.CurrentFilter == "all" ? "is-active" : string.Empty)" href="/du-an">Tất cả</a>
            <a class="@(Model.CurrentFilter == "in-progress" ? "is-active" : string.Empty)" href="/du-an/dang-thuc-hien">Đang thực hiện</a>
            <a class="@(Model.CurrentFilter == "completed" ? "is-active" : string.Empty)" href="/du-an/da-hoan-thanh">Đã hoàn thành</a>
        </div>
        <div class="card-grid card-grid--projects">
            @foreach (var project in Model.Projects)
            {
                @await Html.PartialAsync("_ProjectCard", project)
            }
        </div>
        @if (Model.TotalPages > 1)
        {
            <nav class="pagination-bar" aria-label="Phân trang dự án">
                <a class="pagination-bar__link @(Model.CurrentPage == 1 ? "is-disabled" : null)"
                   href="@(Model.CurrentPage == 1 ? "#" : GetPageUrl(Model.CurrentPage - 1))"
                   aria-disabled="@(Model.CurrentPage == 1 ? "true" : "false")">
                    Trước
                </a>
                <div class="pagination-bar__pages">
                    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                    {
                        <a class="pagination-bar__page @(pageNumber == Model.CurrentPage ? "is-active" : null)"
                           href="@GetPageUrl(pageNumber)">
                            @pageNumber
                        </a>
                    }
                </div>
                <a class="pagination-bar__link @(Model.CurrentPage == Model.TotalPages ? "is-disabled" : null)"
                   href="@(Model.CurrentPage == Model.TotalPages ? "#" : GetPageUrl(Model.CurrentPage + 1))"
                   aria-disabled="@(Model.CurrentPage == Model.TotalPages ? "true" : "false")">
                    Sau
                </a>
            </nav>
        }
    </div>
</section>
