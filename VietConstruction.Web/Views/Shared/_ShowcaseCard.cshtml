@model ShowcaseCardViewModel

<article class="showcase-card">
    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" alt="@Model.Title" loading="lazy" />
    }
    <div class="showcase-card__body">
        @if (!string.IsNullOrWhiteSpace(Model.Tag))
        {
            <span class="card-tag">@Model.Tag</span>
        }
        <h3>@Model.Title</h3>
        @if (!string.IsNullOrWhiteSpace(Model.Meta))
        {
            <span class="card-meta">@Model.Meta</span>
        }
        <p>@Model.Summary</p>
        @if (Model.Facts.Any())
        {
            <dl class="card-facts">
                @foreach (var fact in Model.Facts)
                {
                    <div>
                        <dt>@fact.Label</dt>
                        <dd>@fact.Value</dd>
                    </div>
                }
            </dl>
        }
        @if (!string.IsNullOrWhiteSpace(Model.LinkUrl) && !string.IsNullOrWhiteSpace(Model.LinkLabel))
        {
            <a class="text-link" href="@Model.LinkUrl">@Model.LinkLabel</a>
        }
    </div>
</article>
